{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ABLab",
  "version": "2.0.0",
  "identifier": "com.gobberz.ablab",
  "build": {
    "frontendDist": "../src",
    "devUrl": null,
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "ABLab Quant",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "A/B testing toolkit",
    "longDescription": "Self-contained A/B testing toolkit for quantitative experiment design and inference. 12 modules: data input, sample size, statistical tests, backtest, switchback, CUPED, Bayesian, SRM, sequential testing, multiple comparisons, ratio metrics, and report export.",
    "copyright": "Copyright (c) 2026 Artur Shaimardanov"
  }
}
